# ===========================================
# EmailJS Configuration Template
# ===========================================
# Copy this to your frontend/.env file
# Replace the placeholder values with your actual EmailJS credentials
#
# Get your credentials from:
# https://dashboard.emailjs.com/
# ===========================================

PORT=3002
GENERATE_SOURCEMAP=false

# EmailJS Configuration
# ----------------------------------------
# Service ID: Get from Email Services section
# Example: service_abc1234
REACT_APP_EMAILJS_SERVICE_ID=service_xxxxxx

# Template ID: Get from Email Templates section  
# Example: template_xyz5678
REACT_APP_EMAILJS_TEMPLATE_ID=template_xxxxxx

# Public Key: Get from Account > General section
# Example: AbCdEfG12345XyZ
REACT_APP_EMAILJS_PUBLIC_KEY=AbCdEfG12345

# ===========================================
# Instructions:
# ===========================================
# 1. Sign up at https://www.emailjs.com/
# 2. Add an email service (Gmail, Outlook, etc.)
# 3. Create an email template using the HTML from EMAILJS_QUICK_START.md
# 4. Copy your Service ID, Template ID, and Public Key
# 5. Replace the values above
# 6. Save this file
# 7. Restart your dev server: npm start
# 8. Test using the EmailJsTest component
#
# See EMAILJS_QUICK_START.md for detailed setup instructions
# ===========================================
