# Production Environment Variables Template
# Copy this to .env.prod and fill in actual values
# DO NOT commit .env.prod to git!

# ============================================
# Django Core Settings
# ============================================
DEBUG=False
SECRET_KEY=<use-secret-manager>
ALLOWED_HOSTS=your-backend-url.run.app,api.yourdomain.com
ENVIRONMENT=production

# ============================================
# Database Configuration (Cloud SQL)
# ============================================
DB_NAME=tcu_ceaa
DB_USER=tcu_admin
DB_PASSWORD=<use-secret-manager>
DB_HOST=/cloudsql/PROJECT_ID:REGION:INSTANCE_NAME
DB_PORT=5432

# ============================================
# AWS Configuration
# ============================================
USE_CLOUD_STORAGE=True
AWS_ACCESS_KEY_ID=<use-secret-manager>
AWS_SECRET_ACCESS_KEY=<use-secret-manager>
AWS_STORAGE_BUCKET_NAME=<use-secret-manager>
AWS_S3_REGION_NAME=us-east-1
AWS_S3_CUSTOM_DOMAIN=your-bucket.s3.amazonaws.com
AWS_DEFAULT_ACL=private
AWS_S3_OBJECT_PARAMETERS={"CacheControl": "max-age=86400"}

# ============================================
# AWS Cognito (Face Liveness)
# ============================================
AWS_COGNITO_IDENTITY_POOL_ID=<use-secret-manager>

# ============================================
# AWS Services
# ============================================
USE_ADVANCED_OCR=True
ADVANCED_OCR_REGION=us-east-1
VERIFICATION_SERVICE_ENABLED=True
VERIFICATION_SERVICE_REGION=us-east-1
VERIFICATION_SERVICE_TYPE=rekognition

# ============================================
# Application Settings
# ============================================
FACE_SIMILARITY_THRESHOLD=0.99
VERIFICATION_MAX_ATTEMPTS=3
VERIFICATION_COOLDOWN_HOURS=24

# ============================================
# Email Configuration
# ============================================
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-app-password
DEFAULT_FROM_EMAIL=TCU-CEAA Portal <noreply@tcu-ceaa.edu.ph>

# ============================================
# CORS Settings
# ============================================
CORS_ALLOWED_ORIGINS=https://your-frontend-url.run.app,https://yourdomain.com
CORS_ALLOW_CREDENTIALS=True

# ============================================
# Security Settings
# ============================================
SECURE_SSL_REDIRECT=True
SESSION_COOKIE_SECURE=True
CSRF_COOKIE_SECURE=True
SECURE_BROWSER_XSS_FILTER=True
SECURE_CONTENT_TYPE_NOSNIFF=True
X_FRAME_OPTIONS=DENY

# ============================================
# Frontend URL
# ============================================
FRONTEND_URL=https://yourdomain.com
